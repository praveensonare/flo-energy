# ============================================================
# Flo Energy – Meter Reading ETL Agent  – Environment Config
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ----------------------------
# Required
# ----------------------------

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL – use either DATABASE_URL or individual vars
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meter_db

# --- OR individual connection vars ---
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=meter_db
# PGUSER=postgres
# PGPASSWORD=postgres

# ----------------------------
# Optional
# ----------------------------

# Logging
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json         # json | console

# SQL output
ENABLE_SQL_OUTPUT=false
SQL_OUTPUT_PATH=/output/meter_readings.sql

# Prometheus metrics endpoint (0 = disabled)
METRICS_PORT=8000

# Webhook notifications (Slack / Teams / custom)
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/...
