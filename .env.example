# ============================================================
# Flo Energy – Meter Reading ETL Agent – Environment Config
# ============================================================
# Copy this file to .env and fill in real values.
# Config is loaded by src/config.py (pydantic-settings).
#
#   cp .env.example .env
#   # edit .env with real credentials
#
# NEVER commit .env to version control.

# ----------------------------
# PostgreSQL  (localhost:5432)
# ----------------------------
# Option A – single DSN (takes precedence over individual vars below)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meter_db

# Option B – individual connection parameters
PGHOST=localhost
PGPORT=5432
PGDATABASE=meter_db
PGUSER=postgres
PGPASSWORD=postgres

# Connection pool (defaults are fine for local dev)
PG_MIN_CONNECTIONS=2
PG_MAX_CONNECTIONS=10

# ----------------------------
# Anthropic / Claude API
# ----------------------------
# Required only for agent mode (python main.py without --no-agent)
# ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------
# Logging
# ----------------------------
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console      # console | json

# ----------------------------
# SQL dry-run output
# ----------------------------
ENABLE_SQL_OUTPUT=false
SQL_OUTPUT_PATH=output/meter_readings.sql

# ----------------------------
# Prometheus metrics
# ----------------------------
METRICS_PORT=0          # 0 = disabled; e.g. 8000 exposes /metrics

# ----------------------------
# Webhook notifications
# ----------------------------
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/...

# ----------------------------
# NEM12 processing service
# ----------------------------
NEM12_QUEUE_MAX_SIZE=100
NEM12_STOP_TIMEOUT_SECONDS=10.0
